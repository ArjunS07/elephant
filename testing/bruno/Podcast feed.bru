meta {
  name: Podcast feed
  type: http
  seq: 3
}

get {
  url: {{feedUrl}}
  body: none
  auth: inherit
}

script:post-response {
  // grab the first proxied media URL so the Stream request can use {{mediaUrl}}
  const b = res.getBody();
  const text = (typeof b === "string") ? b : JSON.stringify(b);
  const m = text.match(/http:\/\/localhost:8080\/media\/[A-Za-z0-9_-]+\/stream\.mp3/);
  if (m) bru.setVar("mediaUrl", m[0]);
}

settings {
  encodeUrl: true
  timeout: 0
}
